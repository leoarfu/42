<!-- PYTHON -->
<div class="py-block" id="python">
    <h2>PYTHON EXERCISES</h2>
    <p class="py-intro">Three exercises covering learning curve cost modelling, factory throughput analysis, and programme cost comparison between COTS and rad-hard production strategies. Python 3.8+ standard library only.</p>

    <div class="py-exercise">
        <h3>Exercise 1 — Learning Curve Model (Wright's Law)</h3>
        <p>Compute satellite unit cost as a function of cumulative production volume for different learning rates.</p>
<pre>
import math

def unit_cost(c1, n, lr):
    """Cost of the Nth unit. lr = learning rate (e.g. 0.20 for 20%)."""
    b = math.log(1 - lr) / math.log(2)
    return c1 * (n ** b)

def total_cost(c1, n_total, lr):
    return sum(unit_cost(c1, n, lr) for n in range(1, n_total + 1))

c1 = 1_000_000   # $1M first-unit cost

print("Unit cost vs cumulative production (first unit = $1M)\n")
print(f"{'Unit N':>8}  {'10%':>12}  {'20%':>12}  {'30%':>12}")
print("-" * 50)
for n in [1, 2, 5, 10, 50, 100, 500, 1000, 1584]:
    row = [unit_cost(c1, n, lr) for lr in [0.10, 0.20, 0.30]]
    print(f"{n:>8}  " + "  ".join(f"${v/1e3:>9.0f}k" for v in row))

print("\nTotal programme cost — 1,584 satellites")
for lr in [0.10, 0.20, 0.30]:
    tc  = total_cost(c1, 1584, lr)
    avg = tc / 1584
    print(f"  {lr*100:.0f}% lr:  total=${tc/1e6:.0f}M   avg=${avg/1e3:.0f}k/sat")

# 1. At 20% lr, what fraction of first-unit cost is the 1,584th satellite?
# 2. How much does moving from 10% to 20% lr save on the total programme?
# 3. If a second constellation (648 sats) starts after completing 1,584,
#    what is the cost of unit 1,585?
</pre>
    </div>

    <div class="py-exercise">
        <h3>Exercise 2 — Factory Throughput and Deployment Balance</h3>
        <p>Model production line throughput and check whether the factory can keep pace with the launch cadence and the steady-state replacement rate.</p>
<pre>
def throughput(stations, cycle_hr, yield_rate=0.98):
    """Good satellites per day from a production line."""
    raw = stations * 24 / cycle_hr
    return raw, raw * yield_rate

def deploy_analysis(n_sats, good_per_day, launches_per_yr,
                    sats_per_launch, design_life_yr):
    launch_capacity_yr = launches_per_yr * sats_per_launch
    assembly_days = n_sats / good_per_day
    launch_days   = (n_sats / sats_per_launch) * (365 / launches_per_yr)
    replacement_yr = n_sats / design_life_yr
    print(f"  Good units/day:      {good_per_day:.1f}")
    print(f"  Launch capacity/yr:  {launch_capacity_yr:.0f} sats")
    print(f"  Bottleneck:          {'FACTORY' if assembly_days > launch_days else 'LAUNCH'}")
    print(f"  Deploy time:         {max(assembly_days,launch_days)/365:.1f} yr")
    print(f"  Steady-state replace:{replacement_yr:.0f}/yr  ({replacement_yr/365:.2f}/day)")
    surplus = good_per_day - replacement_yr/365
    print(f"  Factory surplus/day: {surplus:.2f} (for growth or next shell)")

configs = [
    ("Starlink baseline",    2,  11, 15, 53, 5),
    ("OneWeb (2/day)",       1,  12,  8, 36, 5),
    ("Starlink peak",       10,   5, 15, 53, 5),
]
for name, sta, cyc, lyr, spl, dl in configs:
    raw, good = throughput(sta, cyc)
    print(f"\n{name}:")
    deploy_analysis(1584, good, lyr, spl, dl)

# 1. How many stations would Starlink baseline need to halve deploy time?
# 2. At steady-state replacement (5-yr life, 1,584 sats), what is the
#    minimum cycle time needed at 2 stations to stay ahead of demand?
# 3. OneWeb targets 648 satellites. How long to build and deploy at 2/day?
</pre>
    </div>

    <div class="py-exercise">
        <h3>Exercise 3 — Programme Cost: COTS vs Rad-Hard vs GEO</h3>
        <p>Compare total programme cost across manufacturing philosophies for the same LEO constellation and a single GEO HTS satellite.</p>
<pre>
import math

def prog_cost(n_sats, sat_cost, lv_cost_m, spl,
              ground_m, ops_m_yr, life_yr):
    n_lch = -(-n_sats // spl)   # ceiling division
    return {
        "sats_m":    n_sats * sat_cost / 1e6,
        "launch_m":  n_lch * lv_cost_m,
        "ground_m":  ground_m,
        "ops_m":     ops_m_yr * life_yr,
        "launches":  n_lch,
        "unit_k":    sat_cost / 1e3,
    }

def print_case(name, r):
    total = r["sats_m"] + r["launch_m"] + r["ground_m"] + r["ops_m"]
    print(f"\n{name}")
    print(f"  Unit cost:   ${r['unit_k']:.0f}k  ({r['launches']} launches)")
    print(f"  Satellites:  ${r['sats_m']:.0f}M")
    print(f"  Launch:      ${r['launch_m']:.0f}M")
    print(f"  Ground:      ${r['ground_m']:.0f}M")
    print(f"  Operations:  ${r['ops_m']:.0f}M")
    print(f"  TOTAL:       ${total:.0f}M")
    return total

t1 = print_case("LEO mass-produced COTS (1,584 sats, 5yr)",
    prog_cost(1584, 400_000, 20, 53, 300, 50, 5))
t2 = print_case("LEO rad-hard (same constellation, hypothetical)",
    prog_cost(1584, 5_000_000, 80, 20, 800, 200, 5))
t3 = print_case("GEO HTS (single satellite, 15yr)",
    prog_cost(1, 350_000_000, 120, 1, 300, 30, 15))

print(f"\nRad-hard vs COTS multiplier:  {t2/t1:.1f}x more expensive")
print(f"COTS vs GEO total:            ${t1:.0f}M vs ${t3:.0f}M")

# 1. Assuming LEO COTS delivers 1 Tbps and GEO HTS delivers 100 Gbps,
#    compute cost per Gbps for each scenario.
# 2. The COTS LEO programme replaces its fleet every 5 years.
#    Compute 20-year total cost (4 fleet cycles) vs rad-hard (10-yr life, 2 cycles).
# 3. What unit cost would the rad-hard scenario need to reach to match
#    the COTS total programme cost? Is it achievable?
</pre>
    </div>
</div>

