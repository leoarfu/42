      <h3>Exercise 2 — Fleet Telemetry Monitor with Observability Instrumentation</h3>
      <p>Build a fleet-level telemetry monitoring pipeline that ingests telemetry from multiple satellites, evaluates health with context-aware logic (different thresholds for eclipse vs sunlight), emits structured events for each anomaly, and maintains a queryable history. This is the observability-first design pattern Gauthier applies to all ops software.</p>
<pre>
from dataclasses import dataclass, field
from typing import Optional
from collections import defaultdict, deque
from datetime import datetime, timezone, timedelta
import json
import math

# ── Telemetry data model ──────────────────────────────────────────────────
@dataclass
class TelemetrySnapshot:
    satellite_id: str
    timestamp: str
    battery_soc_pct: float
    bus_voltage_v: float
    solar_power_w: float
    payload_active: bool
    adcs_mode: int      # 0=off, 1=detumble, 2=coarse, 3=fine pointing
    orbit_fraction: float  # 0.0–1.0, position in orbit (0.33–0.67 ≈ eclipse for 550km SSO)

    @property
    def in_eclipse(self) -> bool:
        return 0.33 <= self.orbit_fraction <= 0.67

# ── Observable event ─────────────────────────────────────────────────────
@dataclass
class MonitorEvent:
    satellite_id: str
    timestamp: str
    severity: str           # INFO, CAUTION, WARNING, CRITICAL
    category: str           # EPS, ADCS, THERMAL, etc.
    parameter: str
    value: float
    threshold: float
    message: str
    context: dict = field(default_factory=dict)

    def to_dict(self):
        return {
            "satellite_id":  self.satellite_id,
            "timestamp":     self.timestamp,
            "severity":      self.severity,
            "category":      self.category,
            "parameter":     self.parameter,
            "value":         self.value,
            "threshold":     self.threshold,
            "message":       self.message,
            "context":       self.context,
        }

# ── Fleet monitor ─────────────────────────────────────────────────────────
class FleetMonitor:
    """
    Context-aware fleet telemetry monitor.
    Thresholds vary by operational context (eclipse, payload active, etc.).
    Maintains a rolling window of events per satellite for trend analysis.
    """
    EVENT_WINDOW = 20   # events per satellite to keep in memory

    def __init__(self):
        self.event_log: list[MonitorEvent] = []
        self.history: dict[str, deque] = defaultdict(
            lambda: deque(maxlen=self.EVENT_WINDOW)
        )
        self.last_states: dict[str, TelemetrySnapshot] = {}

    def _emit(self, event: MonitorEvent):
        self.event_log.append(event)
        self.history[event.satellite_id].append(event)
        # In production: push to metrics pipeline (Prometheus, Datadog, etc.)
        # Here: print structured JSON
        icons = {"INFO": "ℹ", "CAUTION": "⚠", "WARNING": "⚡", "CRITICAL": "🔴"}
        icon = icons.get(event.severity, "?")
        print(f"  {icon}  [{event.satellite_id}]  {event.severity:<8}  "
              f"{event.category}/{event.parameter}: {event.message}")

    def evaluate(self, tm: TelemetrySnapshot):
        """Evaluate a telemetry snapshot with context-aware thresholds."""
        ctx = {
            "in_eclipse": tm.in_eclipse,
            "payload_active": tm.payload_active,
            "orbit_fraction": tm.orbit_fraction,
        }

        # ── EPS: Battery SoC — tighter limits in eclipse ────────────────
        soc_warning  = 35 if tm.in_eclipse else 40
        soc_critical = 20 if tm.in_eclipse else 25

        if tm.battery_soc_pct <= soc_critical:
            self._emit(MonitorEvent(tm.satellite_id, tm.timestamp, "CRITICAL", "EPS",
                "battery_soc", tm.battery_soc_pct, soc_critical,
                f"SoC {tm.battery_soc_pct:.1f}% at or below critical limit", ctx))
        elif tm.battery_soc_pct <= soc_warning:
            self._emit(MonitorEvent(tm.satellite_id, tm.timestamp, "WARNING", "EPS",
                "battery_soc", tm.battery_soc_pct, soc_warning,
                f"SoC {tm.battery_soc_pct:.1f}% below warning limit", ctx))

        # ── EPS: Solar power — context-aware (zero in eclipse is expected) ──
        if not tm.in_eclipse and tm.solar_power_w < 5.0:
            self._emit(MonitorEvent(tm.satellite_id, tm.timestamp, "WARNING", "EPS",
                "solar_power", tm.solar_power_w, 5.0,
                f"Solar power {tm.solar_power_w:.1f}W unexpectedly low in sunlight", ctx))

        # ── ADCS: Mode sanity check ──────────────────────────────────────
        if tm.adcs_mode == 0:
            self._emit(MonitorEvent(tm.satellite_id, tm.timestamp, "CRITICAL", "ADCS",
                "adcs_mode", tm.adcs_mode, 1.0, "ADCS powered off", ctx))
        elif tm.adcs_mode == 1 and tm.payload_active:
            self._emit(MonitorEvent(tm.satellite_id, tm.timestamp, "WARNING", "ADCS",
                "adcs_mode", tm.adcs_mode, 2.0,
                "Payload active but ADCS still in detumble — pointing not established", ctx))

        # ── Trending: SoC declining across last N snapshots ─────────────
        self._check_soc_trend(tm)

        # Store for next evaluation
        self.last_states[tm.satellite_id] = tm

    def _check_soc_trend(self, tm: TelemetrySnapshot):
        """Flag if SoC has declined more than 15% without payload being activated."""
        prev = self.last_states.get(tm.satellite_id)
        if prev and not tm.in_eclipse:
            delta = tm.battery_soc_pct - prev.battery_soc_pct
            if delta < -15 and not tm.payload_active:
                self._emit(MonitorEvent(tm.satellite_id, tm.timestamp, "WARNING", "EPS",
                    "soc_trend", delta, -15.0,
                    f"SoC dropped {abs(delta):.1f}% in one step without payload active — investigate solar input",
                    {"prev_soc": prev.battery_soc_pct, "current_soc": tm.battery_soc_pct}))

    def fleet_summary(self):
        """Print a concise fleet health summary."""
        print(f"\n{'─'*55}")
        print(f"  FLEET HEALTH SUMMARY  ·  {len(self.last_states)} satellites monitored")
        print(f"{'─'*55}")
        sev_counts = defaultdict(int)
        for e in self.event_log:
            sev_counts[e.severity] += 1
        for sev in ["CRITICAL", "WARNING", "CAUTION", "INFO"]:
            count = sev_counts.get(sev, 0)
            if count:
                print(f"  {sev:<10} {count} event(s)")
        print(f"  Total events: {len(self.event_log)}")

        # Per-satellite summary
        print(f"\n  Per-satellite recent events:")
        for sat_id, events in self.history.items():
            worst = max((e.severity for e in events),
                        key=lambda s: ["INFO","CAUTION","WARNING","CRITICAL"].index(s),
                        default="NOMINAL")
            print(f"    {sat_id:<12}  worst: {worst}  ({len(events)} events)")

# ── Simulate a fleet pass ─────────────────────────────────────────────────
monitor = FleetMonitor()

print("\n" + "="*55)
print("  FLEET TELEMETRY EVALUATION — SIMULATED PASS BATCH")
print("="*55 + "\n")

