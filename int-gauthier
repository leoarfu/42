    <h2>PYTHON EXERCISES — SATDEVOPS SYSTEMS</h2>
    <p class="py-intro">Two exercises that demonstrate SatDevOps thinking: a state machine framework for mission workflow management, and a telemetry-driven decision engine with observability instrumentation built in from the start.</p>

    <div class="py-exercise">
      <h3>Exercise 1 — Mission Workflow State Machine</h3>
      <p>Build a declarative state machine that models a satellite mission workflow. States, valid transitions, guard conditions, and actions on transition — all defined as data, not scattered across imperative code. This is what runbook-as-code looks like.</p>
<pre>
from dataclasses import dataclass, field
from typing import Callable, Optional, Any
from enum import Enum
import logging
import json
from datetime import datetime, timezone

# ── Structured logging setup ─────────────────────────────────────────────
logging.basicConfig(level=logging.INFO, format='%(message)s')
logger = logging.getLogger("mission_fsm")

def log_event(event: str, **kwargs):
    """Emit a structured JSON log event — observable by any log aggregator."""
    record = {
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "event": event,
        **kwargs
    }
    logger.info(json.dumps(record))

# ── State definitions ────────────────────────────────────────────────────
class MissionState(Enum):
    LEOP                = "LEOP"               # Launch & Early Orbit Phase
    COMMISSIONING       = "COMMISSIONING"      # Subsystem checkout
    NOMINAL_PAYLOAD_OFF = "NOMINAL_PAYLOAD_OFF"
    NOMINAL_PAYLOAD_ON  = "NOMINAL_PAYLOAD_ON"
    ANOMALY_RESPONSE    = "ANOMALY_RESPONSE"
    SAFE_MODE           = "SAFE_MODE"
    END_OF_LIFE         = "END_OF_LIFE"

# ── Transition definition ────────────────────────────────────────────────
@dataclass
class Transition:
    from_state: MissionState
    to_state:   MissionState
    trigger:    str                          # human-readable trigger name
    guard:      Optional[Callable] = None    # returns (bool, reason_str)
    action:     Optional[Callable] = None    # side effect on transition

# ── Spacecraft context (mock telemetry) ──────────────────────────────────
@dataclass
class SpacecraftContext:
    satellite_id: str
    battery_soc_pct: float = 85.0
    bus_nominal: bool = True
    payload_power_on: bool = False
    anomaly_resolved: bool = False
    deorbit_approved: bool = False
    commissioning_complete: bool = False

    def to_dict(self):
        return {
            "satellite_id": self.satellite_id,
            "battery_soc_pct": self.battery_soc_pct,
            "bus_nominal": self.bus_nominal,
            "payload_power_on": self.payload_power_on,
            "anomaly_resolved": self.anomaly_resolved,
            "commissioning_complete": self.commissioning_complete,
        }

# ── Guard functions ──────────────────────────────────────────────────────
def guard_bus_nominal(ctx: SpacecraftContext):
    ok = ctx.bus_nominal and ctx.battery_soc_pct >= 40
    reason = "OK" if ok else f"bus={ctx.bus_nominal}, SoC={ctx.battery_soc_pct:.1f}%"
    return ok, reason

def guard_commissioning_complete(ctx: SpacecraftContext):
    ok = ctx.commissioning_complete
    return ok, "commissioning complete" if ok else "commissioning still in progress"

def guard_payload_safe_to_activate(ctx: SpacecraftContext):
    ok = ctx.battery_soc_pct >= 60 and ctx.bus_nominal
    reason = "power sufficient" if ok else f"insufficient power (SoC={ctx.battery_soc_pct:.1f}%)"
    return ok, reason

def guard_anomaly_resolved(ctx: SpacecraftContext):
    return ctx.anomaly_resolved, "anomaly resolved" if ctx.anomaly_resolved else "anomaly still active"

def guard_deorbit_approved(ctx: SpacecraftContext):
    return ctx.deorbit_approved, "deorbit approved" if ctx.deorbit_approved else "deorbit approval pending"

# ── Action functions ─────────────────────────────────────────────────────
def action_power_on_payload(ctx: SpacecraftContext):
    ctx.payload_power_on = True
    log_event("payload_activated", satellite=ctx.satellite_id, soc=ctx.battery_soc_pct)

def action_power_off_payload(ctx: SpacecraftContext):
    ctx.payload_power_on = False
    log_event("payload_deactivated", satellite=ctx.satellite_id)

def action_enter_safe_mode(ctx: SpacecraftContext):
    ctx.payload_power_on = False
    log_event("safe_mode_entered", satellite=ctx.satellite_id,
              soc=ctx.battery_soc_pct, bus_nominal=ctx.bus_nominal)

def action_resume_from_safe(ctx: SpacecraftContext):
    ctx.anomaly_resolved = False  # reset for next potential anomaly
    log_event("nominal_resumed", satellite=ctx.satellite_id)

# ── State machine class ──────────────────────────────────────────────────
class MissionStateMachine:
    def __init__(self, satellite_id: str, initial_state: MissionState = MissionState.LEOP):
        self.ctx = SpacecraftContext(satellite_id=satellite_id)
        self.state = initial_state
        self.history: list[dict] = []
        self._transitions = self._build_transition_table()
        log_event("fsm_initialised", satellite=satellite_id, initial_state=initial_state.value)

    def _build_transition_table(self) -> list[Transition]:
        return [
            Transition(MissionState.LEOP, MissionState.COMMISSIONING,
                       "first_contact_confirmed", guard=guard_bus_nominal),

            Transition(MissionState.COMMISSIONING, MissionState.NOMINAL_PAYLOAD_OFF,
                       "commissioning_complete", guard=guard_commissioning_complete),

            Transition(MissionState.NOMINAL_PAYLOAD_OFF, MissionState.NOMINAL_PAYLOAD_ON,
                       "activate_payload", guard=guard_payload_safe_to_activate,
                       action=action_power_on_payload),

            Transition(MissionState.NOMINAL_PAYLOAD_ON, MissionState.NOMINAL_PAYLOAD_OFF,
                       "deactivate_payload", action=action_power_off_payload),

            # Safe mode reachable from any nominal state
            Transition(MissionState.NOMINAL_PAYLOAD_ON, MissionState.SAFE_MODE,
                       "safe_mode_command", action=action_enter_safe_mode),
            Transition(MissionState.NOMINAL_PAYLOAD_OFF, MissionState.SAFE_MODE,
                       "safe_mode_command", action=action_enter_safe_mode),
            Transition(MissionState.ANOMALY_RESPONSE, MissionState.SAFE_MODE,
                       "safe_mode_command", action=action_enter_safe_mode),

            # Anomaly transitions
            Transition(MissionState.NOMINAL_PAYLOAD_ON, MissionState.ANOMALY_RESPONSE,
                       "anomaly_detected", action=action_power_off_payload),
            Transition(MissionState.NOMINAL_PAYLOAD_OFF, MissionState.ANOMALY_RESPONSE,
                       "anomaly_detected"),

            Transition(MissionState.ANOMALY_RESPONSE, MissionState.NOMINAL_PAYLOAD_OFF,
                       "anomaly_resolved", guard=guard_anomaly_resolved,
                       action=action_resume_from_safe),

            Transition(MissionState.SAFE_MODE, MissionState.NOMINAL_PAYLOAD_OFF,
                       "safe_mode_exit", guard=guard_bus_nominal,
                       action=action_resume_from_safe),

            # End of life
            Transition(MissionState.NOMINAL_PAYLOAD_OFF, MissionState.END_OF_LIFE,
                       "deorbit_command", guard=guard_deorbit_approved),
        ]

    def trigger(self, trigger_name: str) -> tuple[bool, str]:
        """Attempt a state transition by trigger name. Returns (success, message)."""
        candidates = [t for t in self._transitions
                      if t.from_state == self.state and t.trigger == trigger_name]

        if not candidates:
            msg = f"No transition '{trigger_name}' from state '{self.state.value}'"
            log_event("transition_invalid", satellite=self.ctx.satellite_id,
                      trigger=trigger_name, current_state=self.state.value)
            return False, msg

        t = candidates[0]

        # Evaluate guard
        if t.guard:
            allowed, reason = t.guard(self.ctx)
            if not allowed:
                msg = f"Guard blocked '{trigger_name}': {reason}"
                log_event("transition_blocked", satellite=self.ctx.satellite_id,
                          trigger=trigger_name, reason=reason)
                return False, msg

        # Execute transition
        prev_state = self.state
        self.state = t.to_state
        if t.action:
            t.action(self.ctx)

        self.history.append({
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "trigger": trigger_name,
            "from": prev_state.value,
            "to": self.state.value,
            "context_snapshot": self.ctx.to_dict()
        })

        log_event("transition_executed", satellite=self.ctx.satellite_id,
                  trigger=trigger_name, from_state=prev_state.value,
                  to_state=self.state.value)
        return True, f"{prev_state.value} → {self.state.value}"

    def current_valid_triggers(self) -> list[str]:
        return [t.trigger for t in self._transitions if t.from_state == self.state]

# ── Run a mission lifecycle simulation ───────────────────────────────────
print("\n" + "="*60)
print("  MISSION STATE MACHINE SIMULATION — YAM-10")
print("="*60 + "\n")

fsm = MissionStateMachine("YAM-10")

def step(fsm, trigger, description="", **ctx_updates):
    for k, v in ctx_updates.items():
        setattr(fsm.ctx, k, v)
    ok, msg = fsm.trigger(trigger)
    prefix = "✓" if ok else "✗"
    print(f"  {prefix}  [{trigger}]  {msg}")
    if description:
        print(f"     → {description}")
    print(f"     State: {fsm.state.value} | Valid next: {fsm.current_valid_triggers()}")
    print()

# Mission lifecycle
step(fsm, "first_contact_confirmed", "First pass — bus health confirmed")

step(fsm, "commissioning_complete",
     "Commissioning still in progress",
     commissioning_complete=False)

step(fsm, "commissioning_complete",
     "All subsystems checked out",
     commissioning_complete=True)

step(fsm, "activate_payload",
     "Customer payload powered on",
     battery_soc_pct=75.0)

# Anomaly scenario
print("  --- ANOMALY SCENARIO ---\n")
step(fsm, "anomaly_detected", "Unexpected payload current spike — investigate")
step(fsm, "anomaly_resolved",
     "Root cause identified and corrected",
     anomaly_resolved=True)

step(fsm, "activate_payload", "Resuming customer mission")

# Safe mode scenario
print("  --- SAFE MODE SCENARIO ---\n")
step(fsm, "safe_mode_command",
