for tm in telemetry_batch:
    ctx_str = "ECLIPSE" if tm.in_eclipse else "SUNLIGHT"
    print(f"  Evaluating {tm.satellite_id} [{ctx_str}, SoC={tm.battery_soc_pct:.0f}%, ADCS={tm.adcs_mode}]")
    monitor.evaluate(tm)

# Simulate second pass — YAM-10 SoC dropped further
print("\n  --- SECOND PASS BATCH ---\n")
second_batch = [
    TelemetrySnapshot("YAM-10", (now + timedelta(minutes=92)).isoformat(),
                      18.0, 7.5, 40.0, True,  3, 0.30),  # SoC dropped 19 points!
]
for tm in second_batch:
