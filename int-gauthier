const msg = document.getElementById('completeMsg');
btn.addEventListener('click', () => {
  const done = btn.classList.contains('done');
  if (!done) {
    btn.textContent = '✓ COMPLETE — CLICK TO UNDO';
    btn.classList.add('done');
    msg.style.color = '#aa66ff';
    msg.textContent = 'Session marked complete. Panel 5 ready.';
  } else {
    btn.textContent = 'MARK SESSION COMPLETE';
    btn.classList.remove('done');
    msg.style.color = '#ffffff55';
    msg.textContent = 'Prep session not yet marked complete.';
  }
});

const btt = document.getElementById('backToTop');
window.addEventListener('scroll', () => btt.classList.toggle('visible', window.scrollY > 400));
btt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>
</body>
</html>
